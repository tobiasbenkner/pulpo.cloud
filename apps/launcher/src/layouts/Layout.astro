---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Pulpo" } = Astro.props;
---

<!doctype html>
<html lang="es" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="grain">
    <div class="fixed inset-0 dot-grid opacity-30 pointer-events-none"></div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
