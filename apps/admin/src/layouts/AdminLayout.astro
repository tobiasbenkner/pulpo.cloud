---
import Layout from "./Layout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <!-- Auth guard — redirects to login if not authenticated -->
  <div id="auth-guard" class="hidden">
    <div class="flex">
      <!-- Sidebar -->
      <aside class="w-56 min-h-screen bg-white border-r border-neutral-200 p-4 flex flex-col">
        <a href="/admin/products" class="font-semibold text-lg mb-8 block">Admin</a>
        <nav class="flex flex-col gap-1">
          <a href="/admin/products" class="px-3 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 transition-colors" data-nav="products">
            Productos
          </a>
          <a href="/admin/categories" class="px-3 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 transition-colors" data-nav="categories">
            Categorías
          </a>
          <a href="/admin/website" class="px-3 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 transition-colors" data-nav="website">
            Sitio Web
          </a>
        </nav>
        <div class="mt-auto pt-4 border-t border-neutral-100">
          <button id="logout-btn" class="w-full px-3 py-2 rounded-lg text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-900 transition-colors text-left">
            Logout
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <slot />
      </main>
    </div>
  </div>

  <!-- Loading -->
  <div id="auth-loading" class="flex items-center justify-center min-h-screen text-neutral-400">
    Loading...
  </div>

  <script>
    import { pb } from "@/lib/pb";

    async function checkAuth() {
      const guard = document.getElementById("auth-guard")!;
      const loading = document.getElementById("auth-loading")!;

      if (!pb.authStore.isValid) {
        window.location.href = "/admin/login";
        return;
      }

      try {
        await pb.collection("users").authRefresh();
        loading.classList.add("hidden");
        guard.classList.remove("hidden");
      } catch {
        pb.authStore.clear();
        window.location.href = "/admin/login";
      }
    }

    // Highlight active nav
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>("[data-nav]").forEach((a) => {
      if (path.startsWith(a.href.replace(window.location.origin, ""))) {
        a.classList.add("bg-neutral-100", "text-neutral-900");
      }
    });

    // Logout
    document.getElementById("logout-btn")?.addEventListener("click", () => {
      pb.authStore.clear();
      window.location.href = "/admin/login";
    });

    checkAuth();
  </script>
</Layout>
