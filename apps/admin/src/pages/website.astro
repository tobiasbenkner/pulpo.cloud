---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Sitio Web">
  <div class="max-w-2xl">
    <h1 class="text-2xl font-bold mb-6">Sitio Web</h1>

    <div id="loading" class="text-neutral-400">Loading...</div>

    <form id="config-form" class="hidden space-y-8">
      <div id="form-success" class="hidden p-3 rounded-lg bg-green-50 text-green-700 text-sm">Guardado</div>
      <div id="form-error" class="hidden p-3 rounded-lg bg-red-50 text-red-700 text-sm"></div>

      <!-- Languages -->
      <section>
        <h2 class="text-lg font-semibold mb-4">Idiomas</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Idioma principal</label>
            <select id="f-default-language"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-neutral-900">
              <option value="es">Español (es)</option>
              <option value="de">Deutsch (de)</option>
              <option value="en">English (en)</option>
              <option value="it">Italiano (it)</option>
              <option value="ca">Català (ca)</option>
              <option value="fr">Français (fr)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-2">Idiomas adicionales</label>
            <div id="language-checkboxes" class="flex flex-wrap gap-3">
              <!-- Filled by JS -->
            </div>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section>
        <h2 class="text-lg font-semibold mb-4">Contacto</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Teléfono</label>
            <input id="f-phone" type="text" placeholder="+34 600 000 000"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Google Maps URL (iframe embed)</label>
            <input id="f-maps" type="text" placeholder="https://www.google.com/maps/embed?pb=..."
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
        </div>
      </section>

      <!-- Social -->
      <section>
        <h2 class="text-lg font-semibold mb-4">Redes sociales</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Instagram URL</label>
            <input id="f-instagram" type="text" placeholder="https://instagram.com/..."
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Facebook URL</label>
            <input id="f-facebook" type="text" placeholder="https://facebook.com/..."
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">WhatsApp</label>
            <input id="f-whatsapp" type="text" placeholder="+34600000000"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
        </div>
      </section>

      <!-- Opening Hours -->
      <section>
        <h2 class="text-lg font-semibold mb-4">Horario</h2>
        <div class="space-y-2" id="hours-fields">
          <!-- 7 rows, one per day -->
        </div>
      </section>

      <!-- Save -->
      <div class="pt-2">
        <button type="submit" class="px-6 py-2 bg-neutral-900 text-white rounded-lg text-sm font-medium hover:bg-neutral-800 transition-colors">
          Guardar
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  import { pb } from "@/lib/pb";

  const ALL_LANGUAGES = [
    { code: "es", label: "Español" },
    { code: "de", label: "Deutsch" },
    { code: "en", label: "English" },
    { code: "it", label: "Italiano" },
    { code: "ca", label: "Català" },
    { code: "fr", label: "Français" },
  ];

  const DAYS = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"];
  const DAY_LABELS: Record<string, string> = {
    monday: "Lunes",
    tuesday: "Martes",
    wednesday: "Miércoles",
    thursday: "Jueves",
    friday: "Viernes",
    saturday: "Sábado",
    sunday: "Domingo",
  };

  let configId: string | null = null;

  const formEl = document.getElementById("config-form")!;
  const loadingEl = document.getElementById("loading")!;
  const successEl = document.getElementById("form-success")!;
  const errorEl = document.getElementById("form-error")!;
  const fDefaultLang = document.getElementById("f-default-language") as HTMLSelectElement;
  const langCheckboxes = document.getElementById("language-checkboxes")!;
  const hoursFields = document.getElementById("hours-fields")!;

  const fPhone = document.getElementById("f-phone") as HTMLInputElement;
  const fMaps = document.getElementById("f-maps") as HTMLInputElement;
  const fInstagram = document.getElementById("f-instagram") as HTMLInputElement;
  const fFacebook = document.getElementById("f-facebook") as HTMLInputElement;
  const fWhatsapp = document.getElementById("f-whatsapp") as HTMLInputElement;

  function buildLanguageCheckboxes(activeLanguages: string[], defaultLang: string) {
    langCheckboxes.innerHTML = ALL_LANGUAGES
      .map((l) => {
        const checked = activeLanguages.includes(l.code) && l.code !== defaultLang;
        const isDefault = l.code === defaultLang;
        return `
          <label class="flex items-center gap-2 px-3 py-2 rounded-lg border ${isDefault ? "border-neutral-300 bg-neutral-50 opacity-50" : "border-neutral-200 hover:bg-neutral-50"} cursor-pointer transition-colors">
            <input type="checkbox" value="${l.code}" ${checked ? "checked" : ""} ${isDefault ? "disabled" : ""}
              class="lang-checkbox rounded border-neutral-300 text-neutral-900 focus:ring-neutral-900" />
            <span class="text-sm">${l.label}</span>
          </label>
        `;
      })
      .join("");
  }

  function buildHoursFields(hours: { day: string; open: string; close: string }[] | null) {
    const hoursMap: Record<string, { open: string; close: string }> = {};
    if (hours) {
      for (const h of hours) {
        hoursMap[h.day] = { open: h.open, close: h.close };
      }
    }

    hoursFields.innerHTML = DAYS
      .map((day) => {
        const h = hoursMap[day] || { open: "", close: "" };
        return `
          <div class="flex items-center gap-3">
            <span class="w-24 text-sm font-medium text-neutral-700">${DAY_LABELS[day]}</span>
            <input type="time" value="${h.open}" data-day="${day}" data-field="open"
              class="px-3 py-1.5 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
            <span class="text-neutral-400">–</span>
            <input type="time" value="${h.close}" data-day="${day}" data-field="close"
              class="px-3 py-1.5 border border-neutral-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-transparent" />
          </div>
        `;
      })
      .join("");
  }

  function collectHours(): { day: string; open: string; close: string }[] {
    const result: { day: string; open: string; close: string }[] = [];
    for (const day of DAYS) {
      const open = (hoursFields.querySelector(`[data-day="${day}"][data-field="open"]`) as HTMLInputElement)?.value || "";
      const close = (hoursFields.querySelector(`[data-day="${day}"][data-field="close"]`) as HTMLInputElement)?.value || "";
      result.push({ day, open, close });
    }
    return result;
  }

  function collectLanguages(): string[] {
    const defaultLang = fDefaultLang.value;
    const additional = Array.from(langCheckboxes.querySelectorAll<HTMLInputElement>(".lang-checkbox:checked"))
      .map((cb) => cb.value)
      .filter((l) => l !== defaultLang);
    return [defaultLang, ...additional];
  }

  async function loadConfig() {
    try {
      const records = await pb.collection("website_config").getFullList({ requestKey: null });
      const config = records[0] as any;

      if (config) {
        configId = config.id;
        const langs = (config.languages as string[]) || ["es"];
        const defaultLang = config.default_language || "es";

        fDefaultLang.value = defaultLang;
        buildLanguageCheckboxes(langs, defaultLang);
        buildHoursFields(config.opening_hours);

        fPhone.value = config.phone || "";
        fMaps.value = config.google_maps_url || "";
        fInstagram.value = config.social_instagram || "";
        fFacebook.value = config.social_facebook || "";
        fWhatsapp.value = config.social_whatsapp || "";
      } else {
        buildLanguageCheckboxes(["es"], "es");
        buildHoursFields(null);
      }
    } catch {
      // Collection may not exist yet
      buildLanguageCheckboxes(["es"], "es");
      buildHoursFields(null);
    }

    loadingEl.classList.add("hidden");
    formEl.classList.remove("hidden");
  }

  // Update checkboxes when default language changes
  fDefaultLang.addEventListener("change", () => {
    const current = collectLanguages();
    buildLanguageCheckboxes(current, fDefaultLang.value);
  });

  formEl.addEventListener("submit", async (e) => {
    e.preventDefault();
    successEl.classList.add("hidden");
    errorEl.classList.add("hidden");

    const data = {
      default_language: fDefaultLang.value,
      languages: collectLanguages(),
      phone: fPhone.value.trim(),
      google_maps_url: fMaps.value.trim(),
      social_instagram: fInstagram.value.trim(),
      social_facebook: fFacebook.value.trim(),
      social_whatsapp: fWhatsapp.value.trim(),
      opening_hours: collectHours(),
    };

    try {
      if (configId) {
        await pb.collection("website_config").update(configId, data);
      } else {
        const created = await pb.collection("website_config").create(data);
        configId = created.id;
      }
      successEl.classList.remove("hidden");
      setTimeout(() => successEl.classList.add("hidden"), 3000);
    } catch (err: any) {
      errorEl.textContent = err?.message || "Error al guardar";
      errorEl.classList.remove("hidden");
    }
  });

  loadConfig();
</script>
</AdminLayout>
