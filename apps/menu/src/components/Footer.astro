---
import { Icon } from "astro-icon/components";
---

<footer id="site-footer" class="mt-auto border-t border-sand/60 py-6">
  <div class="mx-auto flex max-w-2xl flex-col items-center gap-3 px-5 text-[13px] text-stone">
    <span id="footer-copyright" class="font-display"></span>
    <div class="flex items-center gap-4">
      <a href="/imprint" id="footer-imprint" class="transition-colors hover:text-bark"></a>
      <a href="/privacy" id="footer-privacy" class="transition-colors hover:text-bark"></a>
      <a href="/apps" aria-label="Admin" class="text-stone-light transition-colors hover:text-bark">
        <Icon name="lucide:settings" class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</footer>

<script>
  function initFooter(config: any, lang: string, t: (key: string, lang: string) => string) {
    const copyright = document.getElementById("footer-copyright");
    if (copyright) copyright.textContent = `${config?.name || ""}`;

    const imprint = document.getElementById("footer-imprint");
    if (imprint) imprint.textContent = t("imprint", lang);

    const privacy = document.getElementById("footer-privacy");
    if (privacy) privacy.textContent = t("privacy", lang);
  }

  (window as any).__initFooter = initFooter;
</script>
