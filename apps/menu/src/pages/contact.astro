---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <!-- Loading state -->
  <div id="loading" class="mx-auto max-w-2xl px-5 py-20 text-center">
    <div class="inline-flex flex-col items-center gap-3">
      <div class="h-5 w-5 animate-spin rounded-full border-2 border-sand-dark border-t-accent"></div>
      <span class="text-sm text-stone" id="loading-text"></span>
    </div>
  </div>

  <!-- Contact content -->
  <div id="contact-content" class="mx-auto max-w-2xl px-5 py-8 hidden">
    <!-- Restaurant name -->
    <h1 id="contact-name" class="reveal font-display text-2xl text-bark"></h1>

    <div class="mt-8 space-y-6">
      <!-- Address -->
      <div class="reveal flex gap-4" style="transition-delay: 60ms">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-accent-light">
          <Icon name="lucide:map-pin" class="h-4 w-4 text-accent" />
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-stone" id="label-address"></h2>
          <p class="mt-1 text-[15px] leading-relaxed text-bark" id="contact-address"></p>
        </div>
      </div>

      <!-- Phone -->
      <div id="phone-section" class="reveal flex gap-4" style="transition-delay: 120ms">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-accent-light">
          <Icon name="lucide:phone" class="h-4 w-4 text-accent" />
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-stone" id="label-phone"></h2>
          <a id="contact-phone" href="#" class="mt-1 block text-[15px] text-bark transition-colors hover:text-accent"></a>
        </div>
      </div>

      <!-- Email -->
      <div id="email-section" class="reveal flex gap-4" style="transition-delay: 180ms">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-accent-light">
          <Icon name="lucide:mail" class="h-4 w-4 text-accent" />
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-stone" id="label-email"></h2>
          <a id="contact-email" href="#" class="mt-1 block text-[15px] text-bark transition-colors hover:text-accent"></a>
        </div>
      </div>

      <!-- Opening Hours -->
      <div id="hours-section" class="reveal flex gap-4" style="transition-delay: 240ms">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-accent-light">
          <Icon name="lucide:clock" class="h-4 w-4 text-accent" />
        </div>
        <div class="flex-1">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-stone" id="label-hours"></h2>
          <table id="hours-table" class="mt-2 w-full text-[14px]">
            <!-- Filled by JS -->
          </table>
        </div>
      </div>

      <!-- Social Links -->
      <div id="social-section" class="reveal hidden" style="transition-delay: 300ms">
        <div class="flex gap-4">
          <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-accent-light">
            <Icon name="lucide:share-2" class="h-4 w-4 text-accent" />
          </div>
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-stone" id="label-social"></h2>
            <div id="social-links" class="mt-2 flex flex-wrap gap-2">
              <!-- Filled by JS -->
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Map -->
    <div id="map-section" class="reveal mt-10 hidden" style="transition-delay: 360ms">
      <div class="overflow-hidden rounded-xl border border-sand">
        <iframe
          id="google-map"
          class="h-64 w-full sm:h-80"
          style="border:0"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { t, getLang } from "@/lib/i18n";

  const PB_URL = import.meta.env.DEV ? "http://localhost:8090" : "";

  async function fetchJSON<T>(path: string): Promise<T> {
    const res = await fetch(`${PB_URL}${path}`);
    return res.json();
  }

  const socialIcons: Record<string, string> = {
    social_instagram: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
    social_facebook: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
    social_whatsapp: `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  };

  async function init() {
    const [companyRes, menuConfigRes] = await Promise.all([
      fetchJSON<{ items: any[] }>("/api/collections/company/records"),
      fetchJSON<{ items: any[] }>("/api/collections/website_config/records").catch(() => ({ items: [] })),
    ]);

    const company = companyRes.items[0] || {};
    const menuConfig = menuConfigRes.items[0] || {};
    const config = { ...company, ...menuConfig, _websiteConfig: menuConfig };

    const defaultLang = config.default_language || "es";
    const lang = getLang(new URL(window.location.href), localStorage.getItem("menu-lang") || defaultLang);
    localStorage.setItem("menu-lang", lang);
    document.documentElement.lang = lang;

    (window as any).__initHeader?.(config, lang, t);
    (window as any).__initFooter?.(config, lang, t);

    const loadingText = document.getElementById("loading-text");
    if (loadingText) loadingText.textContent = t("loading", lang);

    // Restaurant name
    setText("contact-name", config.name || "");

    // Labels
    setText("label-address", t("address", lang));
    setText("label-phone", t("phone", lang));
    setText("label-email", t("email", lang));
    setText("label-hours", t("openingHours", lang));
    setText("label-social", t("followUs", lang));

    // Address
    const parts = [config.street, config.postcode && config.city ? `${config.postcode} ${config.city}` : config.city].filter(Boolean);
    const addressEl = document.getElementById("contact-address");
    if (addressEl) {
      addressEl.innerHTML = parts.join("<br>");
    }

    // Phone
    if (config.phone) {
      const phoneEl = document.getElementById("contact-phone") as HTMLAnchorElement | null;
      if (phoneEl) {
        phoneEl.textContent = config.phone;
        phoneEl.href = `tel:${config.phone.replace(/\s/g, "")}`;
      }
    } else {
      hide("phone-section");
    }

    // Email
    if (config.email) {
      const emailEl = document.getElementById("contact-email") as HTMLAnchorElement | null;
      if (emailEl) {
        emailEl.textContent = config.email;
        emailEl.href = `mailto:${config.email}`;
      }
    } else {
      hide("email-section");
    }

    // Opening Hours
    const hours = config.opening_hours as { day: string; open: string; close: string }[] | null;
    if (hours && hours.length > 0) {
      const table = document.getElementById("hours-table");
      if (table) {
        for (const entry of hours) {
          const row = document.createElement("tr");

          const dayCell = document.createElement("td");
          dayCell.className = "py-1.5 font-medium text-bark";
          dayCell.textContent = t(entry.day, lang);

          const timeCell = document.createElement("td");
          timeCell.className = "py-1.5 text-right text-stone";
          timeCell.textContent = entry.open && entry.close
            ? `${entry.open} \u2013 ${entry.close}`
            : t("closed", lang);

          row.appendChild(dayCell);
          row.appendChild(timeCell);
          table.appendChild(row);
        }
      }
    } else {
      hide("hours-section");
    }

    // Social Links
    const socials: { key: string; label: string; urlPrefix?: string }[] = [
      { key: "social_instagram", label: "Instagram" },
      { key: "social_facebook", label: "Facebook" },
      { key: "social_whatsapp", label: "WhatsApp", urlPrefix: "https://wa.me/" },
    ];
    const socialLinksEl = document.getElementById("social-links");
    let hasSocials = false;

    for (const s of socials) {
      const value = config[s.key];
      if (!value) continue;
      hasSocials = true;

      const link = document.createElement("a");
      link.href = s.urlPrefix ? `${s.urlPrefix}${value}` : value;
      link.target = "_blank";
      link.rel = "noopener noreferrer";
      link.className = "inline-flex items-center gap-2 rounded-full border border-sand bg-cream-dark/50 px-4 py-2 text-[13px] font-medium text-bark transition-colors hover:border-accent hover:text-accent";
      link.innerHTML = `${socialIcons[s.key] || ""}${s.label}`;
      socialLinksEl?.appendChild(link);
    }
    if (hasSocials) show("social-section");

    // Google Maps
    if (config.google_maps_url) {
      const iframe = document.getElementById("google-map") as HTMLIFrameElement | null;
      if (iframe) {
        iframe.src = config.google_maps_url;
        show("map-section");
      }
    }

    // Show content & trigger reveals
    document.getElementById("loading")?.classList.add("hidden");
    document.getElementById("contact-content")?.classList.remove("hidden");

    requestAnimationFrame(() => {
      document.querySelectorAll(".reveal").forEach((el) => {
        el.classList.add("visible");
      });
    });
  }

  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function hide(id: string) {
    document.getElementById(id)?.classList.add("hidden");
  }

  function show(id: string) {
    document.getElementById(id)?.classList.remove("hidden");
  }

  init();
</script>
