---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Menu">
  <!-- Category filter -->
  <div class="sticky top-14 z-40 border-b border-sand/40 bg-cream/85 backdrop-blur-md">
    <div class="mx-auto max-w-2xl px-5 py-2.5">
      <div id="category-nav" class="flex gap-2 overflow-x-auto no-scrollbar">
        <!-- Filled by JS -->
      </div>
    </div>
  </div>

  <!-- Loading state -->
  <div id="loading" class="mx-auto max-w-2xl px-5 py-20 text-center">
    <div class="inline-flex flex-col items-center gap-3">
      <div class="h-5 w-5 animate-spin rounded-full border-2 border-sand-dark border-t-accent"></div>
      <span class="text-sm text-stone" id="loading-text"></span>
    </div>
  </div>

  <!-- Menu content -->
  <div id="menu-content" class="mx-auto max-w-2xl px-5 pb-12 pt-6 hidden">
    <!-- Filled by JS -->
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-bark/90 backdrop-blur-sm" role="dialog" aria-modal="true">
    <button id="lightbox-close" class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-white/20" aria-label="Close">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img id="lightbox-img" class="max-h-[85vh] max-w-[90vw] rounded-lg object-contain opacity-0 transition-opacity duration-200" alt="" />
  </div>
</Layout>

<script>
  import { t, getLang } from "@/lib/i18n";

  const PB_URL = import.meta.env.DEV ? "http://localhost:8090" : "";

  interface Config {
    name?: string;
    languages?: string[];
    default_language?: string;
    _websiteConfig?: any;
    [key: string]: any;
  }

  interface Translatable {
    translations?: Record<string, Record<string, string>>;
    [key: string]: any;
  }

  interface Category extends Translatable {
    id: string;
    name: string;
    description: string;
    image: string;
    sort: number;
  }

  interface Product extends Translatable {
    id: string;
    name: string;
    description: string;
    note: string;
    price_gross: string;
    image: string;
    category: string;
    sort: number;
    collectionId?: string;
  }

  function tr(record: Translatable, field: string, lang: string, defaultLang: string): string {
    if (lang !== defaultLang) {
      const val = record.translations?.[field]?.[lang];
      if (val) return val;
    }
    return record[field] || "";
  }

  async function fetchJSON<T>(path: string): Promise<T> {
    const res = await fetch(`${PB_URL}${path}`);
    return res.json();
  }

  function fileUrl(collectionId: string, recordId: string, filename: string): string {
    if (!filename) return "";
    return `${PB_URL}/api/files/${collectionId}/${recordId}/${filename}`;
  }

  async function init() {
    const [companyRes, menuConfigRes, categoriesRes, productsRes] = await Promise.all([
      fetchJSON<{ items: any[] }>("/api/collections/company/records"),
      fetchJSON<{ items: any[] }>("/api/collections/website_config/records").catch(() => ({ items: [] })),
      fetchJSON<{ items: Category[] }>("/api/collections/products_categories/records?sort=sort"),
      fetchJSON<{ items: (Product & { collectionId: string })[] }>("/api/collections/products/records?sort=sort"),
    ]);

    const company = companyRes.items[0] || {};
    const menuConfig = menuConfigRes.items[0] || {};
    const config: Config = { ...company, ...menuConfig, _websiteConfig: menuConfig };
    const categories = categoriesRes.items || [];
    const products = productsRes.items || [];

    const defaultLang = config.default_language || "es";
    const lang = getLang(new URL(window.location.href), localStorage.getItem("menu-lang") || defaultLang);
    localStorage.setItem("menu-lang", lang);
    document.documentElement.lang = lang;

    (window as any).__initHeader?.(config, lang, t);
    (window as any).__initFooter?.(config, lang, t);

    const loadingText = document.getElementById("loading-text");
    if (loadingText) loadingText.textContent = t("loading", lang);

    // Build category filter
    const categoryNav = document.getElementById("category-nav");
    if (categoryNav) {
      categoryNav.appendChild(createCategoryButton(t("allCategories", lang), "all", true));
      for (const cat of categories) {
        categoryNav.appendChild(createCategoryButton(tr(cat, "name", lang, defaultLang), cat.id, false));
      }
    }

    // Build menu sections
    const menuContent = document.getElementById("menu-content");
    if (menuContent) {
      let revealDelay = 0;

      for (const cat of categories) {
        const catProducts = products.filter((p) => p.category === cat.id);
        if (catProducts.length === 0) continue;

        const section = document.createElement("section");
        section.dataset.category = cat.id;
        section.className = "mb-10";

        // Category heading
        const headingWrap = document.createElement("div");
        headingWrap.className = "reveal mb-5 flex items-center gap-3";
        headingWrap.style.transitionDelay = `${revealDelay}ms`;

        const heading = document.createElement("h2");
        heading.className = "font-display text-xl text-bark whitespace-nowrap";
        heading.textContent = tr(cat, "name", lang, defaultLang);
        headingWrap.appendChild(heading);

        const line = document.createElement("div");
        line.className = "h-px flex-1 bg-sand";
        headingWrap.appendChild(line);

        section.appendChild(headingWrap);
        revealDelay += 60;

        // Check if any product in this category has an image
        const hasAnyImage = catProducts.some((p) => p.image && p.collectionId);

        // Products container
        const list = document.createElement("div");
        list.className = hasAnyImage ? "grid gap-3" : "flex flex-col gap-0";

        for (const prod of catProducts) {
          const card = hasAnyImage
            ? createImageCard(prod, lang, defaultLang)
            : createTextCard(prod, lang, defaultLang);
          card.classList.add("reveal");
          card.style.transitionDelay = `${revealDelay}ms`;
          list.appendChild(card);
          revealDelay += 40;
        }

        section.appendChild(list);
        menuContent.appendChild(section);
      }
    }

    // Show content, trigger reveals
    document.getElementById("loading")?.classList.add("hidden");
    menuContent?.classList.remove("hidden");

    requestAnimationFrame(() => {
      document.querySelectorAll(".reveal").forEach((el) => {
        el.classList.add("visible");
      });
    });
  }

  function createCategoryButton(label: string, id: string, active: boolean): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.textContent = label;
    btn.dataset.filter = id;
    const base = "whitespace-nowrap rounded-full px-4 py-1.5 text-[13px] font-medium transition-all duration-200";
    btn.className = active
      ? `${base} bg-accent text-white shadow-sm`
      : `${base} bg-sand/50 text-stone hover:bg-sand hover:text-bark`;

    btn.addEventListener("click", () => {
      document.querySelectorAll<HTMLButtonElement>("[data-filter]").forEach((b) => {
        b.className = `${base} bg-sand/50 text-stone hover:bg-sand hover:text-bark`;
      });
      btn.className = `${base} bg-accent text-white shadow-sm`;

      const sections = document.querySelectorAll<HTMLElement>("[data-category]");
      sections.forEach((s) => {
        s.style.display = id === "all" || s.dataset.category === id ? "" : "none";
      });
    });

    return btn;
  }

  /** Card layout for categories that have images */
  function createImageCard(product: Product & { collectionId?: string }, lang: string, defaultLang: string): HTMLElement {
    const card = document.createElement("div");
    card.className = "flex gap-4 rounded-xl bg-cream-dark/50 p-3 transition-colors hover:bg-cream-dark";

    const imgUrl = product.image && product.collectionId
      ? fileUrl(product.collectionId, product.id, product.image)
      : "";

    if (imgUrl) {
      const img = document.createElement("img");
      img.src = imgUrl;
      img.alt = tr(product, "name", lang, defaultLang);
      img.className = "h-20 w-20 flex-shrink-0 cursor-pointer rounded-lg object-cover transition-opacity hover:opacity-80";
      img.loading = "lazy";
      img.addEventListener("click", () => openLightbox(imgUrl, img.alt));
      card.appendChild(img);
    } else {
      // Placeholder for alignment
      const placeholder = document.createElement("div");
      placeholder.className = "flex h-20 w-20 flex-shrink-0 items-center justify-center rounded-lg bg-sand/40";
      const icon = document.createElement("span");
      icon.className = "text-2xl text-stone-light/60";
      icon.textContent = "\u2022";
      placeholder.appendChild(icon);
      card.appendChild(placeholder);
    }

    const info = document.createElement("div");
    info.className = "flex flex-1 flex-col justify-center min-w-0";

    const top = document.createElement("div");
    top.className = "flex items-start justify-between gap-2";

    const name = document.createElement("h3");
    name.className = "text-[15px] font-semibold leading-snug text-bark";
    name.textContent = tr(product, "name", lang, defaultLang);
    top.appendChild(name);

    if (product.price_gross) {
      const price = document.createElement("span");
      price.className = "flex-shrink-0 text-[15px] font-semibold text-accent";
      price.textContent = formatPrice(product.price_gross);
      top.appendChild(price);
    }

    info.appendChild(top);

    const description = tr(product, "description", lang, defaultLang);
    if (description) {
      const desc = document.createElement("p");
      desc.className = "mt-1 text-[13px] leading-relaxed text-stone line-clamp-2";
      desc.textContent = description.replace(/<[^>]*>/g, "");
      info.appendChild(desc);
    }

    const note = tr(product, "note", lang, defaultLang);
    if (note) {
      const noteEl = document.createElement("p");
      noteEl.className = "mt-0.5 text-xs italic text-stone-light";
      noteEl.textContent = note.replace(/<[^>]*>/g, "");
      info.appendChild(noteEl);
    }

    card.appendChild(info);
    return card;
  }

  /** Classic text-only layout with dotted leader */
  function createTextCard(product: Product & { collectionId?: string }, lang: string, defaultLang: string): HTMLElement {
    const item = document.createElement("div");
    item.className = "border-b border-sand/50 py-3 last:border-b-0";

    // Name ... Price row
    const row = document.createElement("div");
    row.className = "flex items-baseline";

    const name = document.createElement("h3");
    name.className = "text-[15px] font-semibold text-bark whitespace-nowrap";
    name.textContent = tr(product, "name", lang, defaultLang);
    row.appendChild(name);

    if (product.price_gross) {
      const leader = document.createElement("span");
      leader.className = "dotted-leader";
      row.appendChild(leader);

      const price = document.createElement("span");
      price.className = "text-[15px] font-semibold text-accent whitespace-nowrap";
      price.textContent = formatPrice(product.price_gross);
      row.appendChild(price);
    }

    item.appendChild(row);

    const description = tr(product, "description", lang, defaultLang);
    if (description) {
      const desc = document.createElement("p");
      desc.className = "mt-1 text-[13px] leading-relaxed text-stone";
      desc.textContent = description.replace(/<[^>]*>/g, "");
      item.appendChild(desc);
    }

    const note = tr(product, "note", lang, defaultLang);
    if (note) {
      const noteEl = document.createElement("p");
      noteEl.className = "mt-0.5 text-xs italic text-stone-light";
      noteEl.textContent = note.replace(/<[^>]*>/g, "");
      item.appendChild(noteEl);
    }

    return item;
  }

  // ── Lightbox ──
  function openLightbox(src: string, alt: string) {
    const lightbox = document.getElementById("lightbox");
    const img = document.getElementById("lightbox-img") as HTMLImageElement | null;
    if (!lightbox || !img) return;

    img.src = src;
    img.alt = alt;
    img.classList.remove("opacity-100");
    img.classList.add("opacity-0");

    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";

    requestAnimationFrame(() => {
      img.classList.remove("opacity-0");
      img.classList.add("opacity-100");
    });
  }

  function closeLightbox() {
    const lightbox = document.getElementById("lightbox");
    const img = document.getElementById("lightbox-img") as HTMLImageElement | null;
    if (!lightbox) return;

    img?.classList.remove("opacity-100");
    img?.classList.add("opacity-0");

    setTimeout(() => {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
    }, 200);
  }

  document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
  document.getElementById("lightbox")?.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });

  function formatPrice(value: string): string {
    const num = parseFloat(value);
    if (isNaN(num)) return value;
    return num.toFixed(2).replace(".", ",") + " \u20AC";
  }

  init();
</script>
