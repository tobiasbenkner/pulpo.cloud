---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Menu">
  <!-- Loading state -->
  <div id="loading" class="mx-auto max-w-2xl px-5 py-20 text-center">
    <div class="inline-flex flex-col items-center gap-3">
      <div class="h-5 w-5 animate-spin rounded-full border-2 border-sand-dark border-t-accent"></div>
      <span class="text-sm text-stone" id="loading-text"></span>
    </div>
  </div>

  <!-- Menu content -->
  <div id="menu-content" class="mx-auto max-w-2xl px-5 pb-12 pt-6 hidden">
    <!-- Filled by JS -->
  </div>

  <!-- Product detail dialog -->
  <div id="product-dialog" class="dialog-backdrop fixed inset-0 z-[100] hidden items-end justify-center bg-bark/85 px-0 pb-0 backdrop-blur-sm sm:items-center sm:p-6" role="dialog" aria-modal="true" aria-labelledby="product-dialog-name">
    <div id="product-dialog-panel" class="dialog-panel relative flex max-h-[92vh] w-full flex-col overflow-hidden rounded-t-2xl bg-cream shadow-2xl sm:max-w-xl sm:rounded-2xl">
      <button id="product-dialog-close" class="absolute right-3 top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-cream/90 text-bark shadow-sm ring-1 ring-black/5 backdrop-blur-sm transition hover:bg-cream hover:shadow-md" aria-label="Close">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <div id="product-dialog-image-wrap" class="relative aspect-[16/11] w-full shrink-0 overflow-hidden bg-cream-dark">
        <img id="product-dialog-img" class="h-full w-full object-cover" alt="" />
      </div>

      <div class="flex-1 overflow-y-auto px-6 py-6 sm:px-8 sm:py-7">
        <h2 id="product-dialog-name" class="font-display text-2xl leading-tight text-bark sm:text-3xl"></h2>
        <p id="product-dialog-price" class="mt-1 text-base font-medium text-accent"></p>
        <p id="product-dialog-description" class="mt-4 text-[14.5px] leading-relaxed text-bark-light"></p>
        <p id="product-dialog-note" class="mt-2 text-sm italic text-stone"></p>

        <div id="product-dialog-allergens-wrap" class="mt-7 hidden border-t border-sand pt-5">
          <h3 id="product-dialog-allergens-label" class="text-[11px] font-medium uppercase tracking-[0.18em] text-stone"></h3>
          <div id="product-dialog-allergens" class="mt-3 flex flex-wrap gap-2"></div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { t, getLang } from "@/lib/i18n";
  import { pb, loadConfig } from "@/lib/pb";
  import type { RecordModel } from "pocketbase";

  interface Translatable extends RecordModel {
    translations?: Record<string, Record<string, string>>;
  }

  interface Category extends Translatable {
    name: string;
    description: string;
    image: string;
    sort: number;
  }

  interface Product extends Translatable {
    name: string;
    description: string;
    note: string;
    price_gross: string;
    image: string;
    category: string;
    sort: number;
    allergens?: string[];
  }

  function tr(record: Translatable, field: string, lang: string, defaultLang: string): string {
    if (lang !== defaultLang) {
      const val = record.translations?.[field]?.[lang];
      if (val) return val;
    }
    return (record as any)[field] || "";
  }

  async function init() {
    const [config, categories, products] = await Promise.all([
      loadConfig(),
      pb.collection("products_categories").getFullList<Category>({ sort: "sort", requestKey: null }),
      pb.collection("products").getFullList<Product>({ sort: "sort", requestKey: null }),
    ]);

    const defaultLang = config.default_language || "es";
    const lang = getLang(new URL(window.location.href), defaultLang, config.languages);
    localStorage.setItem("menu-lang", lang);
    document.documentElement.lang = lang;

    (window as any).__initHeader?.(config, lang, t);
    (window as any).__initFooter?.(config, lang, t);
    if (config.name) document.title = `${t("menu", lang)} | ${config.name}`;

    const loadingText = document.getElementById("loading-text");
    if (loadingText) loadingText.textContent = t("loading", lang);

    // Build menu sections
    const menuContent = document.getElementById("menu-content");
    if (menuContent) {
      let revealDelay = 0;
      let categoryIndex = 0;

      for (const cat of categories) {
        const catProducts = products.filter((p) => p.category === cat.id);
        if (catProducts.length === 0) continue;
        categoryIndex++;

        const section = document.createElement("section");
        section.dataset.category = cat.id;
        // Asymmetric rhythm: generous space above (separates categories), tighter below
        section.className = categoryIndex === 1 ? "pb-2" : "pt-16 pb-2";

        // Sticky category heading
        const headingBar = document.createElement("div");
        headingBar.className = "sticky-heading reveal sticky top-14 -mx-5 mb-6 bg-cream/95 px-5 backdrop-blur-sm";
        headingBar.style.transitionDelay = `${revealDelay}ms`;
        headingBar.style.zIndex = "30";

        const inner = document.createElement("div");
        inner.className = "border-b border-bark/25 py-3";

        const heading = document.createElement("h2");
        heading.className = "font-display text-xl text-bark leading-none whitespace-nowrap";
        heading.textContent = tr(cat, "name", lang, defaultLang);
        inner.appendChild(heading);

        headingBar.appendChild(inner);

        section.appendChild(headingBar);
        revealDelay += 60;

        // Products container
        const list = document.createElement("div");
        list.className = "flex flex-col";

        for (let i = 0; i < catProducts.length; i++) {
          const prod = catProducts[i];
          const nextProd = catProducts[i + 1];
          const hasImage = !!prod.image;
          const nextHasImage = !!nextProd?.image;
          const showBorder = hasImage && nextHasImage;
          const card = createProductCard(prod, lang, defaultLang, showBorder);
          card.classList.add("reveal");
          card.style.transitionDelay = `${revealDelay}ms`;
          list.appendChild(card);
          revealDelay += 40;
        }

        section.appendChild(list);
        menuContent.appendChild(section);
      }
    }

    // Show content, trigger reveals
    document.getElementById("loading")?.classList.add("hidden");
    menuContent?.classList.remove("hidden");

    requestAnimationFrame(() => {
      document.querySelectorAll(".reveal").forEach((el) => {
        el.classList.add("visible");
      });
    });
  }

  /** Product card — dotted leader without image, vertical stack with image */
  function createProductCard(product: Product, lang: string, defaultLang: string, showBorder = false): HTMLElement {
    const imgUrl = product.image ? pb.files.getURL(product, product.image) : "";
    const hasImage = !!imgUrl;
    const productName = tr(product, "name", lang, defaultLang);

    const item = document.createElement("div");
    item.setAttribute("role", "button");
    item.setAttribute("tabindex", "0");
    item.setAttribute("aria-label", `${t("moreInfo", lang)}: ${productName}`);
    item.addEventListener("click", () => openProductDialog(product, lang, defaultLang, imgUrl));
    item.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openProductDialog(product, lang, defaultLang, imgUrl);
      }
    });

    if (hasImage) {
      // ── With image: vertical stack + thumbnail right ──
      item.className = `product-row flex cursor-pointer items-center gap-4 py-3${showBorder ? " border-b border-sand/40" : ""}`;

      const text = document.createElement("div");
      text.className = "flex-1 min-w-0";

      const name = document.createElement("h3");
      name.className = "product-name text-[15px] font-semibold text-bark transition-colors";
      name.textContent = productName;
      text.appendChild(name);

      if (product.price_gross) {
        const price = document.createElement("p");
        price.className = "mt-0.5 text-[14px] font-medium text-accent";
        price.textContent = formatPrice(product.price_gross);
        text.appendChild(price);
      }

      appendDescription(text, product, lang, defaultLang);
      item.appendChild(text);

      const img = document.createElement("img");
      img.src = imgUrl;
      img.alt = productName;
      img.className = "h-20 w-20 flex-shrink-0 rounded-lg object-cover transition-opacity";
      img.loading = "lazy";
      item.appendChild(img);
    } else {
      // ── Without image: dotted leader ──
      item.className = "product-row cursor-pointer py-2";

      const row = document.createElement("div");
      row.className = "flex items-baseline";

      const name = document.createElement("h3");
      name.className = "product-name text-[15px] font-semibold text-bark transition-colors";
      name.textContent = productName;
      row.appendChild(name);

      if (product.price_gross) {
        const leader = document.createElement("span");
        leader.className = "dotted-leader";
        row.appendChild(leader);

        const price = document.createElement("span");
        price.className = "text-[15px] font-semibold text-accent whitespace-nowrap";
        price.textContent = formatPrice(product.price_gross);
        row.appendChild(price);
      }

      item.appendChild(row);
      appendDescription(item, product, lang, defaultLang);
    }

    return item;
  }

  /** Shared: append description + note */
  function appendDescription(parent: HTMLElement, product: Product, lang: string, defaultLang: string) {
    const description = tr(product, "description", lang, defaultLang);
    if (description) {
      const desc = document.createElement("p");
      desc.className = "mt-0.5 text-[13px] leading-relaxed text-stone";
      desc.textContent = description.replace(/<[^>]*>/g, "");
      parent.appendChild(desc);
    }

    const note = tr(product, "note", lang, defaultLang);
    if (note) {
      const noteEl = document.createElement("p");
      noteEl.className = "mt-0.5 text-xs italic text-stone-light";
      noteEl.textContent = note.replace(/<[^>]*>/g, "");
      parent.appendChild(noteEl);
    }
  }

  // ── Product detail dialog ──
  function openProductDialog(product: Product, lang: string, defaultLang: string, imgUrl: string) {
    const dialog = document.getElementById("product-dialog");
    const panel = document.getElementById("product-dialog-panel");
    const imgWrap = document.getElementById("product-dialog-image-wrap");
    const img = document.getElementById("product-dialog-img") as HTMLImageElement | null;
    const nameEl = document.getElementById("product-dialog-name");
    const priceEl = document.getElementById("product-dialog-price");
    const descEl = document.getElementById("product-dialog-description");
    const noteEl = document.getElementById("product-dialog-note");
    const allergenWrap = document.getElementById("product-dialog-allergens-wrap");
    const allergenLabel = document.getElementById("product-dialog-allergens-label");
    const allergenList = document.getElementById("product-dialog-allergens");
    if (!dialog || !panel || !imgWrap || !img || !nameEl || !priceEl || !descEl || !noteEl || !allergenWrap || !allergenLabel || !allergenList) return;

    const name = tr(product, "name", lang, defaultLang);

    // Image
    if (imgUrl) {
      img.src = imgUrl;
      img.alt = name;
      imgWrap.classList.remove("hidden");
    } else {
      img.removeAttribute("src");
      imgWrap.classList.add("hidden");
    }

    // Text
    nameEl.textContent = name;
    priceEl.textContent = product.price_gross ? formatPrice(product.price_gross) : "";
    priceEl.classList.toggle("hidden", !product.price_gross);

    const description = tr(product, "description", lang, defaultLang).replace(/<[^>]*>/g, "");
    descEl.textContent = description;
    descEl.classList.toggle("hidden", !description);

    const note = tr(product, "note", lang, defaultLang).replace(/<[^>]*>/g, "");
    noteEl.textContent = note;
    noteEl.classList.toggle("hidden", !note);

    // Allergens
    allergenList.replaceChildren();
    if (product.allergens && product.allergens.length > 0) {
      allergenLabel.textContent = t("allergens", lang);
      for (const key of product.allergens) {
        const chip = document.createElement("span");
        chip.className = "allergen-chip inline-flex items-center gap-2 rounded-full border border-sand bg-cream-dark pl-1.5 pr-3 py-1 text-[12px] text-bark-light";
        const icon = document.createElement("img");
        icon.src = `/allergens/${key}.svg`;
        icon.alt = "";
        icon.className = "h-6 w-6";
        const label = document.createElement("span");
        label.textContent = t(key, lang);
        chip.appendChild(icon);
        chip.appendChild(label);
        allergenList.appendChild(chip);
      }
      allergenWrap.classList.remove("hidden");
    } else {
      allergenWrap.classList.add("hidden");
    }

    dialog.classList.remove("hidden");
    dialog.classList.add("flex");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => dialog.classList.add("is-open"));

    const closeBtn = document.getElementById("product-dialog-close") as HTMLButtonElement | null;
    closeBtn?.focus();
  }

  function closeProductDialog() {
    const dialog = document.getElementById("product-dialog");
    if (!dialog) return;
    dialog.classList.remove("is-open");
    setTimeout(() => {
      dialog.classList.add("hidden");
      dialog.classList.remove("flex");
      document.body.style.overflow = "";
    }, 180);
  }

  document.getElementById("product-dialog-close")?.addEventListener("click", closeProductDialog);
  document.getElementById("product-dialog")?.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) closeProductDialog();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeProductDialog();
  });

  function formatPrice(value: string): string {
    const num = parseFloat(value);
    if (isNaN(num)) return value;
    return num.toFixed(2).replace(".", ",") + " \u20AC";
  }

  init();
</script>

