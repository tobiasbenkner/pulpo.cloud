---
import type { VerifyTranslations } from "./verify.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";
import logo from "@/assets/logo.png";

interface Props {
  lang: Language;
  t: VerifyTranslations;
}

const { lang, t } = Astro.props;
---

<section class="flex min-h-[70vh] items-center py-20 md:py-32">
  <div class="mx-auto w-full max-w-[400px] px-6 lg:px-8">
    <div class="text-center">
      <a href={getTranslatedPath("home", lang)} class="inline-block">
        <img src={logo.src} alt="Pulpo" width="48" height="48" class="mx-auto h-12 w-12" />
      </a>
    </div>

    <!-- Loading state -->
    <div id="verify-loading" class="mt-8 text-center">
      <div class="mx-auto h-8 w-8 animate-spin rounded-full border-2 border-sand border-t-coral-500"></div>
      <p class="mt-4 text-sm text-navy-500">{t.verifying}</p>
    </div>

    <!-- Success state -->
    <div id="verify-success" class="mt-8 hidden text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-coral-500/10">
        <Icon name="lucide:check" class="h-6 w-6 text-coral-500" />
      </div>
      <h1 class="mt-4 font-display text-xl font-bold text-navy-900">{t.success}</h1>
      <p class="mt-2 text-sm text-navy-400">{t.redirecting} <span id="verify-countdown">5</span>s</p>
    </div>

    <!-- Error state -->
    <div id="verify-error" class="mt-8 hidden text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-coral-500/10">
        <Icon name="lucide:x" class="h-6 w-6 text-coral-500" />
      </div>
      <h1 class="mt-4 font-display text-xl font-bold text-navy-900">{t.errorTitle}</h1>
      <p class="mt-2 text-sm text-navy-500">{t.errorMessage}</p>
      <a
        href={getTranslatedPath("signup", lang)}
        class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-coral-500 hover:text-coral-600"
      >
        {t.backToSignup}
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>

<script>
  const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL || "";

  async function verify() {
    const token = new URLSearchParams(window.location.search).get("token");
    if (!token) {
      showError();
      return;
    }

    try {
      const res = await fetch(`${pbUrl}/api/collections/users/confirm-verification`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token }),
      });

      if (!res.ok) {
        showError();
        return;
      }

      const result = await res.json();

      if (result.token && result.record) {
        localStorage.setItem("pb_token", result.token);
        localStorage.setItem("pb_user", JSON.stringify(result.record));
      }

      document.getElementById("verify-loading")!.classList.add("hidden");
      document.getElementById("verify-success")!.classList.remove("hidden");

      const lang = document.documentElement.lang || "es";
      const paths: Record<string, string> = {
        es: "/onboarding",
        de: "/de/onboarding",
        en: "/en/onboarding",
        it: "/it/onboarding",
      };

      let seconds = 5;
      const countdownEl = document.getElementById("verify-countdown")!;
      const interval = setInterval(() => {
        seconds--;
        countdownEl.textContent = String(seconds);
        if (seconds <= 0) {
          clearInterval(interval);
          window.location.href = paths[lang] || "/onboarding";
        }
      }, 1000);
    } catch {
      showError();
    }
  }

  function showError() {
    document.getElementById("verify-loading")!.classList.add("hidden");
    document.getElementById("verify-error")!.classList.remove("hidden");
  }

  verify();
</script>
