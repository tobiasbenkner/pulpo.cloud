---
import type { PrivacyTranslations } from "./privacy.i18n";
import type { Language } from "@/lib/i18n";

interface Props {
  lang: Language;
  t: PrivacyTranslations;
}

const { t } = Astro.props;
---

<section class="mx-auto max-w-3xl px-6 py-24">
  <h1 class="text-3xl font-bold tracking-tight">{t.title}</h1>
  <div class="prose mt-8 text-gray-600">
    <p>{t.content}</p>
  </div>
</section>
