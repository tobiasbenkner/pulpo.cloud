    },
  },
];

const audiences = [
  {
    num: "01",
    title: {
      es: "Gastronomía",
      de: "Gastronomie",
      en: "Gastronomy",
      it: "Gastronomia",
    },
    description: {
      es: "Offene Tische, Bondruck, Reservierungen, Kostenstellen für Bar, Küche und Terrasse.",
