---
import type { HomeTranslations } from "./home.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: HomeTranslations;
}

const { lang, t } = Astro.props;
---

<!-- Hero -->
<section class="mx-auto max-w-6xl px-6 py-24 text-center md:py-32">
  <h1 class="text-4xl font-bold tracking-tight md:text-6xl">
    {t.hero.title}
  </h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
    {t.hero.subtitle}
  </p>
  <div class="mt-10 flex items-center justify-center gap-4">
    <a href={getTranslatedPath("contact", lang)} class="rounded-lg bg-gray-900 px-6 py-3 text-sm font-medium text-white hover:bg-gray-800 transition-colors">
      {t.hero.cta}
    </a>
    <a href={getTranslatedPath("features", lang)} class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
      {t.hero.secondary}
    </a>
  </div>
</section>

<!-- Feature Highlights -->
<section class="border-t border-gray-100 bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight">{t.highlights.title}</h2>
    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {t.highlights.items.map((item: any) => (
        <div class="rounded-xl border border-gray-200 bg-white p-8 text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-lg bg-gray-900 text-white">
            <Icon name={item.icon} class="h-6 w-6" />
          </div>
          <h3 class="mt-4 text-lg font-semibold">{item.title}</h3>
          <p class="mt-2 text-sm text-gray-600">{item.description}</p>
        </div>
      ))}
    </div>
    <div class="mt-12 text-center">
      <a href={getTranslatedPath("features", lang)} class="text-sm font-medium text-gray-900 underline underline-offset-4 hover:text-gray-600 transition-colors">
        {t.highlights.cta} &rarr;
      </a>
    </div>
  </div>
</section>

<!-- Pricing Teaser -->
<section class="py-24">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight">{t.pricingTeaser.title}</h2>
    <p class="mt-4 text-lg text-gray-600">{t.pricingTeaser.subtitle}</p>
    <div class="mt-8">
      <a href={getTranslatedPath("pricing", lang)} class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
        {t.pricingTeaser.cta}
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="border-t border-gray-100 bg-gray-50 py-24">
  <div class="mx-auto max-w-xl px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight">{t.cta.title}</h2>
    <p class="mt-4 text-gray-600">{t.cta.subtitle}</p>
    <div class="mt-8">
      <a href={getTranslatedPath("contact", lang)} class="rounded-lg bg-gray-900 px-8 py-3 text-sm font-medium text-white hover:bg-gray-800 transition-colors">
        {t.cta.button}
      </a>
    </div>
  </div>
</section>
