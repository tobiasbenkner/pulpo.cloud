---

<!-- ═══════════════════════ HERO ═══════════════════════ -->
<section class="relative overflow-hidden pb-20 pt-12 md:pb-32 md:pt-20">
  <div class="dot-grid pointer-events-none absolute inset-0 text-navy-300/[0.06]"></div>

  <div class="relative mx-auto grid max-w-[1200px] items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
    <!-- Text -->
    <div>
      <div class="animate-reveal section-label text-coral-500">Cloud POS</div>
      <h1
        class="animate-reveal mt-5 max-w-lg font-display text-[2.75rem] font-extrabold leading-[1.05] tracking-tight text-navy-900 [animation-delay:100ms] md:text-[3.75rem] lg:text-[4.25rem]"
      >
        {heroMainText}{" "}
        <span class="text-coral-500">{heroLastWord}</span>
      </h1>
      <p
        class="animate-reveal mt-6 max-w-md text-base leading-relaxed text-navy-500 [animation-delay:200ms] md:text-lg"
      >
        {t.hero.subtitle}
      </p>
      <div
        class="animate-reveal mt-8 flex flex-wrap items-center gap-4 [animation-delay:300ms]"
      >
        <a
          href={getTranslatedPath("contact", lang)}
          class="inline-flex items-center gap-2 rounded-md bg-coral-500 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-coral-600"
        >
          {t.hero.cta}
          <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
        </a>
        <a
          href={getTranslatedPath("features", lang)}
          class="text-sm font-medium text-navy-500 underline decoration-navy-300 underline-offset-4 transition-colors hover:text-navy-800 hover:decoration-navy-500"
        >
          {t.hero.secondary}
        </a>
      </div>
    </div>

    <!-- POS Mockup -->
    <div
      class="animate-reveal-scale relative [animation-delay:250ms]"
    >
      <div
        class="relative overflow-hidden rounded-xl shadow-[0_40px_80px_-20px_rgba(17,23,34,0.25)]"
        style="transform: perspective(1200px) rotateY(-4deg) rotateX(1deg)"
      >
        <svg
          viewBox="0 0 560 380"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="block w-full"
        >
          <rect width="560" height="380" rx="8" fill="#111722" />
          <rect width="560" height="28" rx="8" fill="#1a2332" />
          <rect y="20" width="560" height="8" fill="#1a2332" />
          <circle cx="16" cy="14" r="3.5" fill="#e8546d" opacity="0.8" />
          <circle cx="28" cy="14" r="3.5" fill="#f2748e" opacity="0.3" />
          <circle cx="40" cy="14" r="3.5" fill="#23344d" />
          <text
            x="280"
            y="17"
            text-anchor="middle"
            font-size="8"
            fill="#506b93"
            font-family="system-ui">Pulpo POS</text
          >
          <rect x="0" y="28" width="100" height="352" fill="#0d1219" />
          <rect x="10" y="40" width="80" height="20" rx="3" fill="#e8546d" opacity="0.12" />
          <rect x="18" y="46" width="42" height="7" rx="2" fill="#e8546d" opacity="0.5" />
          <rect x="10" y="66" width="80" height="20" rx="3" fill="transparent" />
          <rect x="18" y="72" width="34" height="7" rx="2" fill="#3a5580" />
          <rect x="10" y="92" width="80" height="20" rx="3" fill="transparent" />
          <rect x="18" y="98" width="46" height="7" rx="2" fill="#3a5580" />
          <rect x="10" y="118" width="80" height="20" rx="3" fill="transparent" />
          <rect x="18" y="124" width="28" height="7" rx="2" fill="#3a5580" />
          {[0, 1, 2].map((row) =>
            [0, 1, 2].map((col) => {
              const x = 112 + col * 96;
              const y = 40 + row * 84;
              return (
                <g>
                  <rect
                    x={x}
                    y={y}
                    width="88"
                    height="74"
                    rx="5"
                    fill="#1a2332"
                  />
                  <rect
                    x={x + 6}
                    y={y + 6}
                    width="76"
                    height="36"
                    rx="3"
                    fill="#23344d"
                  />
                  <rect
                    x={x + 6}
                    y={y + 48}
                    width="44"
                    height="7"
                    rx="2"
                    fill="#506b93"
                  />
                  <rect
                    x={x + 6}
                    y={y + 60}
                    width="28"
                    height="6"
                    rx="2"
                    fill="#e8546d"
                    opacity="0.45"
                  />
                </g>
              );
            }),
          )}
          <rect x="400" y="28" width="160" height="352" fill="#1a2332" />
          <line
            x1="400"
            y1="28"
            x2="400"
            y2="380"
            stroke="#23344d"
            stroke-width="1"
          />
          <rect x="412" y="40" width="56" height="8" rx="2" fill="#8096b4" />
          {[0, 1, 2, 3].map((i) => (
            <g>
              <rect
                x="412"
                y={60 + i * 28}
                width="136"
                height="1"
                fill="#23344d"
              />
              <rect
                x="412"
                y={68 + i * 28}
                width={72 + (i % 3) * 12}
                height="7"
                rx="2"
                fill="#b3c1d5"
              />
              <rect
                x="520"
                y={68 + i * 28}
                width="28"
                height="7"
                rx="2"
                fill="#8096b4"
              />
            </g>
          ))}
          <rect x="412" y="324" width="136" height="1" fill="#23344d" />
          <rect x="412" y="332" width="44" height="8" rx="2" fill="#506b93" />
          <rect
            x="506"
            y="330"
            width="42"
            height="12"
            rx="2"
            fill="#8096b4"
          />
          <rect
            x="412"
            y="354"
            width="136"
            height="18"
            rx="4"
            fill="#e8546d"
          />
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════ BENTO FEATURES ═══════════════════ -->
<section class="py-24 md:py-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
    <div class="flex items-end justify-between" data-reveal>
      <div>
        <div class="section-label text-coral-500">
          {sectionLabels.features[lang]}
        </div>
