          {t.highlights.title}
        </h2>
      </div>
      <a
        href={getTranslatedPath("features", lang)}
        class="hidden items-center gap-1 text-sm font-medium text-navy-500 transition-colors hover:text-coral-500 md:inline-flex"
      >
        {t.highlights.cta}
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-12">
      <!-- POS — large card with mockup -->
      <div
        data-reveal
        class="bento-card grain overflow-hidden rounded-xl bg-navy-800 p-6 text-white md:col-span-7 md:p-8"
      >
        <div class="flex items-start gap-3">
          <div
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-coral-500/15 text-coral-400"
          >
            <Icon name={bento[0].icon} class="h-4 w-4" />
          </div>
          <div>
            <h3 class="font-display text-lg font-bold">{bento[0].title[lang]}</h3>
            <p class="mt-1 text-sm leading-relaxed text-navy-300">
              {bento[0].description[lang]}
            </p>
          </div>
        </div>
        <div class="mt-6 overflow-hidden rounded-lg">
          <svg
            viewBox="0 0 520 200"
            fill="none"
            class="block w-full"
          >
            <rect width="520" height="200" rx="4" fill="#0d1219" />
            {[0, 1, 2, 3].map((col) => (
              <g>
                <rect
                  x={12 + col * 96}
                  y="12"
                  width="84"
                  height="60"
                  rx="4"
                  fill="#1a2332"
                />
                <rect
                  x={18 + col * 96}
                  y="18"
                  width="72"
                  height="30"
                  rx="2"
                  fill="#23344d"
                />
                <rect
                  x={18 + col * 96}
                  y="54"
                  width="40"
                  height="6"
                  rx="2"
                  fill="#506b93"
                />
                <rect
                  x={18 + col * 96}
                  y="64"
                  width="24"
                  height="4"
                  rx="1"
                  fill="#e8546d"
                  opacity="0.4"
                />
              </g>
            ))}
            {[0, 1, 2, 3].map((col) => (
              <g>
                <rect
                  x={12 + col * 96}
                  y="82"
                  width="84"
                  height="60"
                  rx="4"
                  fill="#1a2332"
                />
                <rect
                  x={18 + col * 96}
                  y="88"
                  width="72"
                  height="30"
                  rx="2"
                  fill="#23344d"
                />
                <rect
                  x={18 + col * 96}
                  y="124"
                  width="36"
                  height="6"
                  rx="2"
                  fill="#506b93"
                />
                <rect
                  x={18 + col * 96}
                  y="134"
                  width="24"
                  height="4"
                  rx="1"
                  fill="#e8546d"
                  opacity="0.4"
                />
              </g>
            ))}
            <rect x="400" y="0" width="120" height="200" fill="#1a2332" />
            <rect
              x="412"
              y="12"
              width="96"
              height="14"
              rx="3"
              fill="#e8546d"
            />
            <rect
              x="412"
              y="36"
              width="60"
              height="6"
              rx="2"
              fill="#506b93"
            />
            <rect
              x="486"
              y="36"
              width="22"
              height="6"
              rx="2"
              fill="#8096b4"
            />
            <rect x="412" y="48" width="96" height="1" fill="#23344d" />
            <rect
              x="412"
              y="56"
              width="52"
              height="6"
              rx="2"
              fill="#506b93"
            />
            <rect
              x="486"
              y="56"
              width="22"
              height="6"
              rx="2"
              fill="#8096b4"
            />
            <rect x="412" y="68" width="96" height="1" fill="#23344d" />
            <rect
              x="412"
              y="168"
              width="96"
              height="20"
              rx="4"
              fill="#e8546d"
            />
          </svg>
        </div>
      </div>

      <!-- Invoice -->
      <div
        data-reveal
        style="transition-delay: 100ms"
        class="bento-card flex flex-col justify-between overflow-hidden rounded-xl border-l-[3px] border-coral-500 bg-white p-6 shadow-sm md:col-span-5 md:p-8"
      >
        <div>
          <div
            class="flex h-8 w-8 items-center justify-center rounded-md bg-navy-800 text-white"
          >
            <Icon name={bento[1].icon} class="h-4 w-4" />
          </div>
          <h3 class="mt-4 font-display text-lg font-bold text-navy-900">
            {bento[1].title[lang]}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-navy-500">
            {bento[1].description[lang]}
          </p>
        </div>
        <div class="mt-6 rounded-lg bg-navy-50 p-4">
          <svg viewBox="0 0 280 100" fill="none" class="block w-full">
            <rect
              x="0"
              y="0"
              width="280"
              height="8"
              rx="2"
              fill="#b3c1d5"
            />
            <rect
              x="0"
              y="14"
              width="160"
              height="6"
              rx="2"
              fill="#dce2ec"
            />
            <rect x="0" y="30" width="280" height="1" fill="#dce2ec" />
            <rect
              x="0"
              y="40"
              width="100"
              height="6"
              rx="2"
              fill="#b3c1d5"
            />
            <rect
              x="230"
              y="40"
              width="50"
              height="6"
              rx="2"
              fill="#b3c1d5"
            />
            <rect
              x="0"
              y="54"
              width="120"
              height="6"
              rx="2"
              fill="#b3c1d5"
            />
            <rect
              x="230"
              y="54"
              width="50"
              height="6"
              rx="2"
              fill="#b3c1d5"
            />
            <rect x="0" y="70" width="280" height="1" fill="#dce2ec" />
