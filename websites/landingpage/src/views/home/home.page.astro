        <div class="mt-4 flex items-end gap-1.5" style="height: 48px">
          {[55, 72, 40, 65, 80, 48, 70].map((h) => (
            <div
              class="flex-1 rounded-sm bg-coral-500"
              style={`height: ${h}%; opacity: ${0.25 + (h / 100) * 0.6}`}
            />
          ))}
        </div>
      </div>

      <!-- Online Shop -->
      <div
        data-reveal
        style="transition-delay: 250ms"
        class="bento-card grain overflow-hidden rounded-xl bg-navy-800 p-6 text-white md:col-span-4 md:p-8"
