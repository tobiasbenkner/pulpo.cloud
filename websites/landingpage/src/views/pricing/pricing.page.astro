---
import type { PricingTranslations } from "./pricing.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: PricingTranslations;
}

const { lang, t } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center">
  <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{t.hero.title}</h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">{t.hero.subtitle}</p>
</section>

<!-- Plans -->
<section class="border-t border-gray-100 bg-gray-50 py-24">
  <div class="mx-auto max-w-3xl px-6">
    <div class="grid gap-8 md:grid-cols-2">
      {t.plans.map((plan: any) => (
        <div class:list={["rounded-xl bg-white p-8", plan.highlighted ? "border-2 border-gray-900 shadow-lg" : "border border-gray-200"]}>
          <h2 class="text-xl font-semibold">{plan.name}</h2>
          <p class="mt-2 text-sm text-gray-600">{plan.description}</p>
          <p class="mt-6 text-4xl font-bold">
            {plan.price}<span class="text-base font-normal text-gray-500">{t.monthly}</span>
          </p>
          <ul class="mt-8 space-y-3 text-sm text-gray-600">
            {plan.features.map((f: string) => (
              <li class="flex items-center gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-gray-900" />
                {f}
              </li>
            ))}
          </ul>
          <a
            href={getTranslatedPath("contact", lang)}
            class:list={[
              "mt-8 block rounded-lg py-3 text-center text-sm font-medium transition-colors",
              plan.highlighted
                ? "bg-gray-900 text-white hover:bg-gray-800"
                : "border border-gray-300 hover:bg-gray-50",
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-24">
  <div class="mx-auto max-w-3xl px-6">
    <h2 class="text-2xl font-bold tracking-tight">{t.faq.title}</h2>
    <div class="mt-10 divide-y divide-gray-200">
      {t.faq.items.map((item: any) => (
        <div class="py-6">
          <h3 class="text-base font-semibold">{item.question}</h3>
          <p class="mt-2 text-sm text-gray-600">{item.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
