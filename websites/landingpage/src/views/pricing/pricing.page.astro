---
import type { PricingTranslations } from "./pricing.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { siteData } from "@/data/site";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: PricingTranslations;
}

const { lang, t } = Astro.props;

const { plans, currency, overage } = siteData.pricing;

const planKeys = ["free", "starter", "business", "growth", "scale"] as const;

function formatNumber(n: number): string {
  return n.toLocaleString("de-DE");
}
---

<!-- Hero -->
<section class="pb-16 pt-12 md:pb-24 md:pt-20">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
    <div class="max-w-2xl">
      <div class="animate-reveal section-label text-coral-500">Pricing</div>
      <h1
        class="animate-reveal mt-4 font-display text-4xl font-extrabold tracking-tight text-navy-900 [animation-delay:100ms] md:text-5xl"
      >
        {t.hero.title}
      </h1>
      <p
        class="animate-reveal mt-4 text-lg leading-relaxed text-navy-500 [animation-delay:200ms]"
      >
        {t.hero.subtitle}
      </p>
    </div>
  </div>
</section>

<!-- Pricing Table -->
<section class="pb-24 md:pb-32">
  <div class="mx-auto max-w-[800px] px-6 lg:px-8">
    <!-- All features badge -->
    <div
      data-reveal
      class="mb-8 inline-flex items-center gap-2 rounded-full bg-navy-800 px-4 py-1.5 text-xs font-medium text-white"
    >
      <Icon name="lucide:check" class="h-3.5 w-3.5 text-coral-400" />
      {t.allFeatures}
    </div>

    <!-- Tiers -->
    <div class="divide-y divide-sand" data-reveal style="transition-delay: 80ms">
      {plans.map((plan, i) => {
        const name = t.planNames[planKeys[i] as keyof typeof t.planNames];
        const isFree = plan.price === 0;
        const isScale = planKeys[i] === "scale";
        return (
          <div
            class:list={[
              "grid grid-cols-[1fr_auto] items-center gap-4 py-5 md:grid-cols-[140px_1fr_auto]",
              isScale && "pb-4",
            ]}
          >
            <div class="font-display text-base font-bold text-navy-900">
              {name}
            </div>
            <div class="hidden text-sm text-navy-500 md:block">
              {t.upTo} {formatNumber(plan.invoices)} {t.invoicesPerMonth}
            </div>
            <div class="text-right">
              {isFree ? (
                <span class="font-display text-2xl font-extrabold text-coral-500">
                  0{currency}
                </span>
              ) : (
                <span class="font-display text-2xl font-extrabold text-navy-900">
                  {plan.price}
                  {currency}
                  <span class="text-sm font-normal text-navy-400">
                    {t.invoicesPerMonth.includes("/")
                      ? ""
                      : "/"}Mo
                  </span>
                </span>
              )}
            </div>
            <div class="col-span-2 text-sm text-navy-400 md:hidden">
              {t.upTo} {formatNumber(plan.invoices)} {t.invoicesPerMonth}
            </div>
          </div>
        );
      })}

      <!-- Overage row -->
      <div class="grid grid-cols-[1fr_auto] items-center gap-4 py-5 md:grid-cols-[140px_1fr_auto]">
        <div class="font-display text-base font-bold text-navy-400">
          10.000+
        </div>
        <div class="hidden text-sm text-navy-500 md:block">
          {t.thenPerInvoice}
        </div>
        <div class="text-right">
          <span class="font-display text-2xl font-extrabold text-navy-900">
            +{String(overage).replace(".", ",")}
            {currency}
          </span>
          <span class="text-sm font-normal text-navy-400">
            {" "}{t.perInvoice}
          </span>
        </div>
        <div class="col-span-2 text-sm text-navy-400 md:hidden">
          {t.thenPerInvoice}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-10" data-reveal style="transition-delay: 160ms">
      <a
        href={getTranslatedPath("contact", lang)}
        class="inline-flex items-center gap-2 rounded-md bg-coral-500 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-coral-600"
      >
        {t.cta}
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>

<!-- Open Source -->
<section class="border-y border-sand py-20">
  <div class="mx-auto max-w-[800px] px-6 lg:px-8">
    <div data-reveal class="grid gap-6 md:grid-cols-[auto_1fr] md:gap-10">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-navy-800 text-white">
        <Icon name="lucide:github" class="h-6 w-6" />
      </div>
      <div>
        <h2 class="font-display text-xl font-bold text-navy-900">
          {t.openSource.title}
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-navy-500">
          {t.openSource.description}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="grain overflow-hidden bg-navy-900 py-24 text-white md:py-32">
  <div class="mx-auto max-w-[800px] px-6 lg:px-8">
    <h2 data-reveal class="font-display text-2xl font-bold tracking-tight">
      {t.faq.title}
    </h2>
    <div class="mt-10 divide-y divide-navy-700">
      {t.faq.items.map((item: any, i: number) => (
        <div
          data-reveal
          style={`transition-delay: ${i * 80}ms`}
          class="py-6 first:pt-0 last:pb-0"
        >
          <h3 class="font-display font-semibold">{item.question}</h3>
          <p class="mt-2 text-sm leading-relaxed text-navy-300">
            {item.answer}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
