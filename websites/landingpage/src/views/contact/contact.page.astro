---
import type { ContactTranslations } from "./contact.i18n";
import type { Language } from "@/lib/i18n";
import { siteData } from "@/data/site";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: ContactTranslations;
}

const { lang, t } = Astro.props;

const whatsappUrl = `https://wa.me/${siteData.contact.whatsapp.replace(/[^0-9]/g, "")}`;
---

<!-- Hero -->
<section class="py-20 md:py-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
    <div class="max-w-2xl">
      <div class="animate-reveal section-label text-coral-500">
        {t.email.label}
      </div>
      <h1
        class="animate-reveal mt-4 font-display text-4xl font-extrabold tracking-tight text-navy-900 [animation-delay:100ms] md:text-5xl lg:text-6xl"
      >
        {t.hero.title}
      </h1>
      <p
        class="animate-reveal mt-6 max-w-md text-lg leading-relaxed text-navy-500 [animation-delay:200ms]"
      >
        {t.hero.subtitle}
      </p>
    </div>

    <!-- Contact options -->
    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Email -->
      <a
        href={`mailto:${siteData.contact.email}`}
        data-reveal
        class="group flex gap-4 rounded-xl border border-sand bg-white p-6 shadow-sm transition-all hover:border-coral-200 hover:shadow-md"
      >
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-coral-500 text-white transition-colors group-hover:bg-coral-600">
          <Icon name="lucide:mail" class="h-5 w-5" />
        </div>
        <div>
          <h2 class="font-display text-base font-bold text-navy-900">{t.email.label}</h2>
          <p class="mt-1 text-sm text-navy-500">{t.email.description}</p>
          <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-coral-500">
            {t.email.cta}
            <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
          </span>
        </div>
      </a>

      <!-- WhatsApp -->
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        data-reveal
        style="transition-delay: 80ms"
        class="group flex gap-4 rounded-xl border border-sand bg-white p-6 shadow-sm transition-all hover:border-green-300 hover:shadow-md"
      >
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-[#25D366] text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
        </div>
        <div>
          <h2 class="font-display text-base font-bold text-navy-900">{t.whatsapp.label}</h2>
          <p class="mt-1 text-sm text-navy-500">{t.whatsapp.description}</p>
          <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-[#25D366]">
            {t.whatsapp.cta}
            <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
          </span>
        </div>
      </a>

      <!-- Demo -->
      <a
        href="https://demo.pulpo.cloud"
        target="_blank"
        rel="noopener"
        data-reveal
        style="transition-delay: 160ms"
        class="group flex gap-4 rounded-xl border border-sand bg-white p-6 shadow-sm transition-all hover:border-navy-300 hover:shadow-md"
      >
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-navy-800 text-white">
          <Icon name="lucide:play" class="h-5 w-5" />
        </div>
        <div>
          <h2 class="font-display text-base font-bold text-navy-900">{t.demo.title}</h2>
          <p class="mt-1 text-sm text-navy-500">{t.demo.description}</p>
          <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-navy-800">
            {t.demo.cta}
            <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
          </span>
        </div>
      </a>
    </div>
  </div>
</section>
