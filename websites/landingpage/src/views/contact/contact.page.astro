---
import type { ContactTranslations } from "./contact.i18n";
import type { Language } from "@/lib/i18n";
import { siteData } from "@/data/site";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: ContactTranslations;
}

const { lang, t } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center md:py-32">
  <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{t.hero.title}</h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">{t.hero.subtitle}</p>
</section>

<section class="border-t border-gray-100 bg-gray-50 py-24">
  <div class="mx-auto max-w-md px-6 text-center">
    <div class="rounded-xl border border-gray-200 bg-white p-10">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-gray-900 text-white">
        <Icon name="lucide:mail" class="h-6 w-6" />
      </div>
      <h2 class="mt-6 text-lg font-semibold">{t.email.label}</h2>
      <a
        href={`mailto:${siteData.contact.email}`}
        class="mt-2 inline-block text-lg text-gray-600 hover:text-gray-900 transition-colors"
      >
        {siteData.contact.email}
      </a>
    </div>
  </div>
</section>
