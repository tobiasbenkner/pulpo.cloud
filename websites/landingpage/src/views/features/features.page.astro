---
import type { FeaturesTranslations } from "./features.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: FeaturesTranslations;
}

const { lang, t } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center">
  <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{t.hero.title}</h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">{t.hero.subtitle}</p>
</section>

<section class="border-t border-gray-100 bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-12 md:grid-cols-2">
      {t.items.map((item: any) => (
        <div class="flex gap-6">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-gray-900 text-white">
            <Icon name={item.icon} class="h-6 w-6" />
          </div>
          <div>
            <h2 class="text-xl font-semibold">{item.title}</h2>
            <p class="mt-2 text-gray-600">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <a
        href={getTranslatedPath("pricing", lang)}
        class="rounded-lg bg-gray-900 px-8 py-3 text-sm font-medium text-white hover:bg-gray-800 transition-colors"
      >
        {t.cta.text}
      </a>
    </div>
  </div>
</section>
