---
import type { FeaturesTranslations } from "./features.i18n";
import type { Language } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  t: FeaturesTranslations;
}

const { lang, t } = Astro.props;
---

<!-- Hero -->
<section class="pb-16 pt-12 md:pb-24 md:pt-20">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
    <div class="max-w-2xl">
      <div class="animate-reveal section-label text-coral-500">
        {t.hero.title}
      </div>
      <h1
        class="animate-reveal mt-4 font-display text-4xl font-extrabold tracking-tight text-navy-900 [animation-delay:100ms] md:text-5xl"
      >
        {t.hero.subtitle}
      </h1>
    </div>
  </div>
</section>

<!-- Features -->
<section class="pb-24 md:pb-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
    <div class="divide-y divide-sand">
      {t.items.map((item: any, i: number) => (
        <div
          data-reveal
          style={`transition-delay: ${(i % 3) * 80}ms`}
          class="grid gap-6 py-12 first:pt-0 last:pb-0 md:grid-cols-12 md:gap-10"
        >
          <div class="flex items-start gap-4 md:col-span-5">
            <span class="font-display text-sm font-bold text-coral-500/30">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-md bg-navy-800 text-white">
                  <Icon name={item.icon} class="h-4 w-4" />
                </div>
                <h2 class="font-display text-xl font-bold text-navy-900">
                  {item.title}
                </h2>
              </div>
            </div>
          </div>
          <div class="md:col-span-5">
            <p class="text-sm leading-relaxed text-navy-500">
              {item.description}
            </p>
          </div>
          <div class="md:col-span-2">
            <div class="img-placeholder flex aspect-[3/2] items-center justify-center rounded-lg">
              <Icon name="lucide:image" class="h-5 w-5 text-navy-500" />
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center" data-reveal>
      <a
        href={getTranslatedPath("pricing", lang)}
        class="inline-flex items-center gap-2 rounded-md bg-coral-500 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-coral-600"
      >
        {t.cta.text}
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>
