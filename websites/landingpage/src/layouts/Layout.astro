---
import "../styles/global.css";
import type { Language } from "@/lib/i18n";
import { languages } from "@/lib/i18n";
import { getTranslatedPath, getRouteLabel } from "@/lib/registry";
import { siteData } from "@/data/site";
import { Icon } from "astro-icon/components";
import logo from "@/assets/logo.png";

interface Props {
  title: string;
  description?: string;
  lang: Language;
  routeKey: string;
}

const { title, description, lang, routeKey } = Astro.props;

const mainNav = ["home", "features", "pricing", "contact"] as const;
const legalNav = ["imprint", "privacy", "terms"] as const;
const authRoutes = ["login", "signup", "onboarding"];
const isAuthPage = authRoutes.includes(routeKey);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script defer src="https://analytics.pulpo.cloud/script.js" data-website-id="36ee02cf-1e66-48aa-8476-c2023bfc5678" is:inline></script>
    )}
    <link rel="canonical" href={`${siteData.meta.url}${getTranslatedPath(routeKey, lang)}`} />
    {languages.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={`${siteData.meta.url}${getTranslatedPath(routeKey, l)}`}
      />
    ))}
    <noscript>
      <style>
        [data-reveal] {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>

  <body class="flex min-h-dvh flex-col bg-cream text-navy-800">
    {isAuthPage ? (
      <!-- Minimal header for auth pages -->
      <header class="bg-cream">
        <div class="mx-auto max-w-[1200px] px-6 py-4 lg:px-8">
          <a
            href={getTranslatedPath("home", lang)}
            class="inline-flex items-center gap-1 text-sm text-navy-400 transition-colors hover:text-navy-800"
          >
            <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" />
            {{
              es: "Volver",
              de: "Zurück",
              en: "Back",
              it: "Indietro",
            }[lang]}
          </a>
        </div>
      </header>
    ) : (
      <!-- Full header -->
      <header class="sticky top-0 z-50 bg-cream/92 backdrop-blur-md">
        <div class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4 lg:px-8">
          <a
            href={getTranslatedPath("home", lang)}
            class="flex items-center gap-2"
          >
            <img src={logo.src} alt="" width="28" height="28" class="h-7 w-7" />
            <span class="font-display text-base font-bold tracking-tight">
              {siteData.meta.name}
            </span>
          </a>

          <nav class="hidden items-center gap-7 md:flex">
            {mainNav.map((key) => (
              <a
                href={getTranslatedPath(key, lang)}
                class:list={[
                  "nav-link text-[13px] font-medium text-navy-500 transition-colors hover:text-navy-800",
                  routeKey === key && "active text-navy-800",
                ]}
              >
                {getRouteLabel(key, lang)}
              </a>
            ))}
          </nav>

          <div class="flex items-center gap-4">
            <div class="hidden items-center gap-1.5 text-[11px] text-navy-400 sm:flex">
              {languages.map((l, i) => (
                <>
                  {i > 0 && <span class="text-navy-200">/</span>}
                  {l === lang ? (
                    <span class="font-medium text-navy-800">
                      {l.toUpperCase()}
                    </span>
                  ) : (
                    <a
                      href={getTranslatedPath(routeKey, l)}
                      data-lang-switch={l}
                      class="transition-colors hover:text-coral-500"
                    >
                      {l.toUpperCase()}
                    </a>
                  )}
                </>
              ))}
            </div>
            <a
              href={getTranslatedPath("signup", lang)}
              class="hidden items-center gap-1.5 rounded-md bg-coral-500 px-4 py-1.5 text-[13px] font-medium text-white transition-colors hover:bg-coral-600 sm:inline-flex"
            >
              {getRouteLabel("signup", lang)}
              <Icon name="lucide:arrow-right" class="h-3 w-3" />
            </a>
            <button
              id="menu-toggle"
              class="relative z-[60] p-1.5 text-navy-600 md:hidden"
              aria-label="Menu"
            >
              <Icon name="lucide:menu" id="icon-menu" class="h-5 w-5" />
              <Icon name="lucide:x" id="icon-close" class="hidden h-5 w-5" />
            </button>
          </div>
        </div>
      </header>
    )}

    {!isAuthPage && (
      <!-- Fullscreen mobile menu -->
      <div
        id="mobile-menu"
        class="fixed inset-0 z-50 hidden flex-col bg-cream md:hidden"
      >
        <!-- Top bar mirroring header -->
        <div class="flex items-center justify-between px-6 py-4">
          <a
            href={getTranslatedPath("home", lang)}
            class="flex items-center gap-2"
          >
            <img src={logo.src} alt="" width="28" height="28" class="h-7 w-7" />
            <span class="font-display text-base font-bold tracking-tight">
              {siteData.meta.name}
            </span>
          </a>
          <button
            id="menu-close"
            class="p-1.5 text-navy-600"
            aria-label="Close menu"
          >
            <Icon name="lucide:x" class="h-5 w-5" />
          </button>
        </div>

        <!-- Nav links -->
        <nav class="flex flex-1 flex-col justify-center px-8">
          {mainNav.map((key) => (
            <a
              href={getTranslatedPath(key, lang)}
              class:list={[
                "border-b border-sand py-5 font-display text-2xl font-bold tracking-tight transition-colors",
                routeKey === key
                  ? "text-coral-500"
                  : "text-navy-800 hover:text-coral-500",
              ]}
            >
              {getRouteLabel(key, lang)}
            </a>
          ))}
        </nav>

        <!-- CTA -->
        <div class="px-8 pb-4">
          <a
            href={getTranslatedPath("signup", lang)}
            class="flex items-center justify-center gap-2 rounded-md bg-coral-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-coral-600"
          >
            {getRouteLabel("signup", lang)}
            <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
          </a>
        </div>

        <!-- Bottom: language switcher -->
        <div class="border-t border-sand px-8 py-6">
          <div class="flex gap-3">
            {languages.map((l) => (
              <a
                href={getTranslatedPath(routeKey, l)}
                data-lang-switch={l}
                class:list={[
                  "text-sm font-medium transition-colors",
                  l === lang
                    ? "text-navy-800"
                    : "text-navy-400 hover:text-navy-600",
                ]}
              >
                {l.toUpperCase()}
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

    <div
      id="lang-toast"
      class="fixed bottom-5 right-5 z-50 hidden translate-y-4 opacity-0 transition-all duration-300"
    >
      <div class="flex items-center gap-3 rounded-lg bg-navy-900 px-4 py-3 text-sm text-navy-200 shadow-lg">
        <Icon name="lucide:globe" class="h-4 w-4 shrink-0 text-coral-400" />
        <span id="lang-toast-text"></span>
        <a
          id="lang-toast-link"
          href="/"
          class="shrink-0 rounded-md bg-coral-500 px-3 py-1 text-xs font-medium text-white transition-colors hover:bg-coral-600"
        ></a>
        <button
          id="lang-toast-close"
          class="shrink-0 p-0.5 text-navy-400 transition-colors hover:text-white"
          aria-label="Close"
        >
          <Icon name="lucide:x" class="h-3.5 w-3.5" />
        </button>
      </div>
    </div>

    <main class="flex-1">
      <slot />
    </main>

    {!isAuthPage && <footer class="bg-navy-900 pb-10 pt-20 text-navy-300">
      <div class="mx-auto max-w-[1200px] px-6 lg:px-8">
        <div class="grid gap-12 md:grid-cols-[1.2fr_auto_auto_auto]">
          <!-- Brand -->
          <div class="max-w-xs">
            <a
              href={getTranslatedPath("home", lang)}
              class="flex items-center gap-2"
            >
              <img
                src={logo.src}
                alt=""
                width="24"
                height="24"
                class="h-6 w-6"
              />
              <span class="font-display text-sm font-bold text-white">
                {siteData.meta.name}
              </span>
            </a>
            <p class="mt-4 text-sm leading-relaxed">
              {{
                es: "Sistema de punto de venta moderno para tu negocio. Rápido, sencillo y desde cualquier dispositivo.",
                de: "Modernes Kassensystem für dein Geschäft. Schnell, einfach und von jedem Gerät aus.",
                en: "Modern point of sale system for your business. Fast, simple and from any device.",
                it: "Sistema di punto vendita moderno per la tua attività. Veloce, semplice e da qualsiasi dispositivo.",
              }[lang]}
            </p>
            <div class="mt-4 flex items-center gap-3">
              <div class="inline-flex items-center gap-1.5 rounded-full border border-navy-700 px-2.5 py-1 text-[10px] font-medium text-navy-300">
                <Icon name="lucide:shield-check" class="h-3 w-3 text-coral-400" />
                VeriFactu-Ready
              </div>
            </div>
            <a
              href={getTranslatedPath("signup", lang)}
              class="mt-6 inline-flex items-center gap-1.5 rounded-md bg-coral-500 px-4 py-2 text-[13px] font-medium text-white transition-colors hover:bg-coral-600"
            >
              {{
                es: "Empezar gratis",
                de: "Kostenlos starten",
                en: "Start for free",
                it: "Inizia gratis",
              }[lang]}
              <Icon name="lucide:arrow-right" class="h-3 w-3" />
            </a>
          </div>

          <!-- Product nav -->
          <div class="text-sm">
            <h4 class="mb-4 text-xs font-semibold uppercase tracking-wider text-navy-400">
              {{
                es: "Producto",
                de: "Produkt",
                en: "Product",
                it: "Prodotto",
              }[lang]}
            </h4>
            <div class="flex flex-col gap-2.5">
              {mainNav.map((key) => (
                <a
                  href={getTranslatedPath(key, lang)}
                  class="transition-colors hover:text-white"
                >
                  {getRouteLabel(key, lang)}
                </a>
              ))}
            </div>
          </div>

          <!-- Legal nav -->
          <div class="text-sm">
            <h4 class="mb-4 text-xs font-semibold uppercase tracking-wider text-navy-400">
              {{
                es: "Legal",
                de: "Rechtliches",
                en: "Legal",
                it: "Legale",
              }[lang]}
            </h4>
            <div class="flex flex-col gap-2.5">
              {legalNav.map((key) => (
                <a
                  href={getTranslatedPath(key, lang)}
                  class="transition-colors hover:text-white"
                >
                  {getRouteLabel(key, lang)}
                </a>
              ))}
            </div>
          </div>

          <!-- Contact -->
          <div class="text-sm">
            <h4 class="mb-4 text-xs font-semibold uppercase tracking-wider text-navy-400">
              {{
                es: "Contacto",
                de: "Kontakt",
                en: "Contact",
                it: "Contatto",
              }[lang]}
            </h4>
            <div class="flex flex-col gap-2.5">
              <a
                href={`https://wa.me/${siteData.contact.whatsapp.replace("+", "")}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 transition-colors hover:text-white"
              >
                <Icon name="lucide:message-circle" class="h-3.5 w-3.5" />
                WhatsApp
              </a>
              <a
                href={getTranslatedPath("contact", lang)}
                class="inline-flex items-center gap-1.5 transition-colors hover:text-white"
              >
                <Icon name="lucide:mail" class="h-3.5 w-3.5" />
                {getRouteLabel("contact", lang)}
              </a>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-navy-800 pt-6 text-xs text-navy-400 sm:flex-row sm:items-center">
          <span>&copy; {new Date().getFullYear()} {siteData.meta.name}</span>
          <div class="flex items-center gap-2">
            {languages.map((l, i) => (
              <>
                {i > 0 && <span class="text-navy-600">/</span>}
                {l === lang ? (
                  <span class="font-medium text-navy-200">{l.toUpperCase()}</span>
                ) : (
                  <a
                    href={getTranslatedPath(routeKey, l)}
                    data-lang-switch={l}
                    class="transition-colors hover:text-navy-200"
                  >
                    {l.toUpperCase()}
                  </a>
                )}
              </>
            ))}
          </div>
        </div>
      </div>
    </footer>}

    <script>
      const menu = document.getElementById("mobile-menu");
      const iconMenu = document.getElementById("icon-menu");
      const iconClose = document.getElementById("icon-close");

      function toggleMenu() {
        const isOpen = menu?.classList.toggle("hidden") === false;
        if (isOpen) {
          menu?.classList.add("flex");
          document.body.style.overflow = "hidden";
        } else {
          menu?.classList.remove("flex");
          document.body.style.overflow = "";
        }
        iconMenu?.classList.toggle("hidden", isOpen);
        iconClose?.classList.toggle("hidden", !isOpen);
      }

      document.getElementById("menu-toggle")?.addEventListener("click", toggleMenu);
      document.getElementById("menu-close")?.addEventListener("click", toggleMenu);

      const observer = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("revealed");
              observer.unobserve(e.target);
            }
          }),
        { threshold: 0.08, rootMargin: "0px 0px -60px 0px" },
      );

      document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));

      document.querySelectorAll<HTMLAnchorElement>("[data-lang-switch]").forEach((link) => {
        link.addEventListener("click", () => {
          const lang = link.getAttribute("data-lang-switch");
          if (lang) localStorage.setItem("pulpo-lang", lang);
        });
      });

      // Language suggestion toast
      (function () {
        const pageLang = document.documentElement.lang;
        if (localStorage.getItem("pulpo-lang")) return;

        const messages: Record<string, { text: string; cta: string }> = {
          de: { text: "Auch auf Deutsch verfügbar.", cta: "Wechseln" },
          en: { text: "Also available in English.", cta: "Switch" },
          it: { text: "Disponibile anche in italiano.", cta: "Cambia" },
          es: { text: "También disponible en español.", cta: "Cambiar" },
        };

        const supported = Object.keys(messages);
        const browserLangs = navigator.languages || [navigator.language];
        let detected: string | null = null;

        for (const bl of browserLangs) {
          const code = bl.split("-")[0].toLowerCase();
          if (code === pageLang) return;
          if (supported.includes(code)) {
            detected = code;
            break;
          }
        }

        if (!detected) return;

        const _toast = document.getElementById("lang-toast");
        const _text = document.getElementById("lang-toast-text");
        const _link = document.getElementById("lang-toast-link") as HTMLAnchorElement | null;
        const _close = document.getElementById("lang-toast-close");

        if (!_toast || !_text || !_link || !_close) return;

        const toast = _toast;
        const text = _text;
        const link = _link;
        const close = _close;

        const msg = messages[detected];
        text.textContent = msg.text;
        link.textContent = msg.cta;
        link.href = detected === "es" ? "/" : `/${detected}`;

        // Show with animation
        toast.classList.remove("hidden");
        requestAnimationFrame(() => {
          toast.classList.remove("translate-y-4", "opacity-0");
        });

        // Auto-hide after 8 seconds
        const autoHide = setTimeout(() => hideToast(pageLang), 8000);

        function hideToast(storeLang: string) {
          clearTimeout(autoHide);
          toast.classList.add("translate-y-4", "opacity-0");
          setTimeout(() => toast.classList.add("hidden"), 300);
          localStorage.setItem("pulpo-lang", storeLang);
        }

        link.addEventListener("click", () => {
          localStorage.setItem("pulpo-lang", detected!);
        });

        close.addEventListener("click", () => hideToast(pageLang));
      })();
    </script>
  </body>
</html>
